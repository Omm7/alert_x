generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  role           Role           @default(USER)
  createdAt      DateTime       @default(now())
  lastLogin      DateTime?
  loginOtpExpiry DateTime?
  loginOtpHash   String?
  branch         String         @default("Computer Science")
  collegeName    String         @default("Unknown College")
  graduationYear Int            @default(2025)
  applications   Application[]
  savedJobs      SavedJob[]
  subscriptions  Subscription[]
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  lastOtpSentAt DateTime?

  @@index([email, expiresAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
}

model Company {
  id      String @id @default(cuid())
  name    String @unique
  logoUrl String
  website String
  jobs    Job[]
}

enum CourseType {
  BTECH
  MTECH
  MCA
  MBA
  BE
  BTech
  BCA
  BSC
  OTHER
}

model Job {
  id               String          @id @default(cuid())
  title            String
  companyId        String
  location         String
  salary           String
  jobType          JobType
  category         JobCategory
  courseType       CourseType      @default(BTECH)
  experienceLevel  ExperienceLevel @default(ENTRY)
  description      String
  requirements     String
  responsibilities String?
  benefits         String?
  applyLink        String
  createdAt        DateTime        @default(now())
  applications     Application[]
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  savedBy          SavedJob[]

  @@index([category, location, jobType])
  @@index([createdAt])
}

model Subscription {
  id          String      @id @default(cuid())
  userId      String
  jobCategory JobCategory
  location    String
  jobType     JobType
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobCategory, location, jobType])
}

model SavedJob {
  id     String @id @default(cuid())
  userId String
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  appliedAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

enum Role {
  USER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERN
  CONTRACT
  OFF_CAMPUS
  ALL
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
}

enum JobCategory {
  SOFTWARE_ENGINEERING
  DATA_SCIENCE
  AI_ML
  CYBERSECURITY
  INTERNSHIP
  OFF_CAMPUS_DRIVE
  ALL
}
